{
  "name": "water-switch-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "esbuild src/server.js --bundle --minify --platform=node --target=node22 --format=esm --outfile=dist/server.js --external:@clerk/* --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\"",
    "start": "node dist/server.js",
    "dev": "nodemon src/server.js"
  },
  "dependencies": {
    "@clerk/express": "^1.7.76",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "nodemon": "^3.1.14"
  }
}
